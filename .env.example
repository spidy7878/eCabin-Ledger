# Local dev (web browser or Android emulator on same machine)
EXPO_PUBLIC_API_URL=http://localhost:4000/api

# Physical Android device on same WiFi — replace with your machine's LAN IP
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4000/api

# Android emulator (AVD)
# EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api

# Production
# EXPO_PUBLIC_API_URL=https://your-production-domain.com/api
